rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    function isValidUrl(url) {
      return url is string &&
             (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ─── /urls/{urlId} ───────────────────────────────────────────────────────

    match /urls/{urlId} {
      // Public read: required for redirect handler + dashboard
      allow read: if true;

      // Anyone can create a short URL (server validates the body)
      allow create: if request.resource.data.keys().hasAll(
                         ['originalUrl', 'shortId', 'clickCount', 'createdAt']
                       ) &&
                       isValidUrl(request.resource.data.originalUrl) &&
                       request.resource.data.clickCount == 0;

      // Two allowed update patterns:
      // 1. Click tracking — only clickCount + clickHistory change
      // 2. Server-side field edits (category, expiry, aiInsights, campaignId)
      allow update: if
        (request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['clickCount', 'clickHistory']) &&
          request.resource.data.clickCount == resource.data.clickCount + 1 &&
          request.resource.data.originalUrl == resource.data.originalUrl &&
          request.resource.data.shortId == resource.data.shortId)
        ||
        (request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly([
            'category', 'expiryDate', 'aiInsights', 'campaignId'
          ]));

      // Allow deletion (dashboard delete button)
      allow delete: if true;
    }

    // ─── /campaigns/{campaignId} ─────────────────────────────────────────────

    match /campaigns/{campaignId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasAll(['name', 'status', 'createdAt']) &&
                       request.resource.data.name is string &&
                       request.resource.data.name.size() > 0;

      allow update: if request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['status', 'description']);

      allow delete: if true;
    }
  }
}
